# ===========================================
# SafeCircle Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# PostgreSQL
POSTGRES_DB=safecircle
POSTGRES_USER=safecircle
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production
MINIO_BUCKET=safecircle
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API
NODE_ENV=development
API_PORT=3000
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Cloud Messaging (for push notifications)
# Get from: Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=

# SMTP (for email verification)
# Free options: Gmail, Yandex, Mail.ru
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Domain (for production Caddy SSL)
DOMAIN=localhost
